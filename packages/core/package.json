{
  "name": "@discoveryos/core",
  "version": "0.0.1",
  "private": true,
  "description": "Shared domain models, types, and schemas for DiscoveryOS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "keywords": [
    "discoveryos",
    "domain-models",
    "types",
    "schemas",
    "validation"
  ]
}
